# =========================================================
# Ghostty 設定ファイル
# =========================================================


# ---------------------------------------------------------
# 見た目・フォント
# ---------------------------------------------------------

# フォントサイズ
font-size = 15

# 行間
adjust-cell-height = 0%

# フォントファミリー
# font-family = "JetBrains Mono"
# font-family = "Iosevka Nerd Font Mono"
# font-family = "Noto Sans Mono CJK JP"
font-family = "Maple Mono NF JP"

# ---------------------------------------------------------
# テーマ
# ---------------------------------------------------------

# テーマ設定 Banana Blueberry, Flexoki Dark, Elementary
theme = Elementary


# ---------------------------------------------------------
# ウィンドウ・透明度
# ---------------------------------------------------------

# 背景の透明度（0.0〜1.0 の範囲）
# 1.0 だと完全不透明、0.0 だと完全透明
background-opacity = 0.97

# 背景のブラー（すりガラス効果）
# 数値を上げるほど、強めにぼける（例：10 / 20 / 30）
background-blur = 20

# ウィンドウ内の余白（横）
window-padding-x = 10

# ウィンドウ内の余白（縦）
window-padding-y = 10

# 余白バランス調整（見た目の左右上下のバランスを取りやすい）
window-padding-balance = true


# ---------------------------------------------------------
# macOS ネイティブっぽい挙動
# ---------------------------------------------------------

# タイトルバーを透明にする（すっきり）
macos-titlebar-style = transparent

# ウィンドウの影（macOS っぽく）
macos-window-shadow = true

# 入力中にマウスカーソルを隠す（タイピング集中）
mouse-hide-while-typing = true


# ---------------------------------------------------------
# 操作性（クリップボードなど）
# ---------------------------------------------------------

# Option キーを Alt として扱う（Vim 系ショートカット等で便利）
macos-option-as-alt = true

# クリップボードの読み取りを許可
clipboard-read = allow

# クリップボードの書き込みを許可
clipboard-write = allow


# ---------------------------------------------------------
# キーバインド設定（画面分割）
# ---------------------------------------------------------

# Cmd + Enter で「下に分割」
keybind = cmd+enter=new_split:down

# Cmd + Shift + Enter で「右に分割」
keybind = cmd+shift+enter=new_split:right


# ---------------------------------------------------------
# タブ移動
# ---------------------------------------------------------

# Option + Cmd + → で次のタブへ移動
keybind = alt+cmd+right=next_tab

# Option + Cmd + ← で前のタブへ移動
keybind = alt+cmd+left=previous_tab


# ---------------------------------------------------------
# 分割したペイン間の移動
# ---------------------------------------------------------

# Cmd + ← で左のペインへ移動
keybind = cmd+left=goto_split:left

# Cmd + → で右のペインへ移動
keybind = cmd+right=goto_split:right

# Cmd + ↑ で上のペインへ移動（top/bottom ではなく up/down を使う）
keybind = cmd+up=goto_split:up

# Cmd + ↓ で下のペインへ移動（top/bottom ではなく up/down を使う）
keybind = cmd+down=goto_split:down


# ---------------------------------------------------------
# 分割サイズの調整
# ---------------------------------------------------------

# Cmd + Shift + ← で左方向にサイズ調整（20 ずつ）
keybind = cmd+shift+left=resize_split:left,20

# Cmd + Shift + → で右方向にサイズ調整（20 ずつ）
keybind = cmd+shift+right=resize_split:right,20

# Cmd + Shift + ↑ で上方向にサイズ調整（20 ずつ）
keybind = cmd+shift+up=resize_split:up,20

# Cmd + Shift + ↓ で下方向にサイズ調整（20 ずつ）
keybind = cmd+shift+down=resize_split:down,20


# ---------------------------------------------------------
# ペイン（分割）を閉じる
# ---------------------------------------------------------

# Cmd + W で「現在のペイン」を閉じる
# デフォルトの挙動だとウィンドウ自体が閉じることがあるため、ここでペインを閉じる動作を優先
keybind = cmd+w=close_surface


# 通知
desktop-notifications = true
